{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mimic Templating Language",
  "scopeName": "source.mimic",
  "patterns": [
    {
      "include": "#curly-braces-expression"
    },
    {
      "include": "#comment"
    }
  ],
  "repository": {
    "curly-braces-expression": {
      "name": "string.template.mimic",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "patterns": [
        {
          "name": "variable.parameter.mimic",
          "match": "[^}]+"
        }
      ]
    },
    "comment": {
      "name": "comment.line.mimic",
      "match": "(?:(?!\\{\\{).)+"
    }
  }
}